# ============================================================
# Plantilla de variables de entorno - NeoSer
# ============================================================
# Copia este archivo como .env.local y rellena con tus claves.
# NUNCA subas .env.local a git (ya está en .gitignore).
# ============================================================

# --- Supabase (obligatorias) ---
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_clave_publica_anon
SUPABASE_SERVICE_ROLE_KEY=tu_clave_secreta_de_servicio

# --- Cal.com (reservas) ---
NEXT_PUBLIC_CAL_BOOKING_URL=https://cal.com/tu-usuario/cita
CAL_WEBHOOK_SIGNING_KEY=tu_secreto_para_validar_webhooks

# --- HubSpot (CRM) ---
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxxxxxx

# --- Email (Brevo o HubSpot transactional) ---
# EMAIL_PROVIDER: "brevo" (envío real) | "hubspot" (stub, no envía)
# EMAIL_API_KEY: si provider=brevo, la API key de Brevo (empieza con "xkeysib-")
# EMAIL_FROM: debe ser un remitente VERIFICADO en Brevo (Settings → Senders)
EMAIL_PROVIDER=brevo
EMAIL_API_KEY=xkeysib-xxxxxxxxxxxx
EMAIL_FROM=neoser.admin@gmail.com

# --- WhatsApp (360dialog) ---
WHATSAPP_PROVIDER=360dialog
DIALOG_API_KEY=xxxxxxxxxxxx
WHATSAPP_FROM=51932713071

# --- Google Maps ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXX

# --- Mercado Pago (pagos V2) ---
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxx
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxxxxxx

# --- Izipay (pagos de cursos) ---
# Dejá IZIPAY_MOCK_MODE=true mientras no haya credenciales reales
IZIPAY_MOCK_MODE=true
IZIPAY_MERCHANT_ID=
IZIPAY_PUBLIC_KEY=
IZIPAY_SECRET_KEY=
IZIPAY_API_BASE_URL=https://api.izipay.pe
