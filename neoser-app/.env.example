# ============================================================
# Plantilla de variables de entorno - NeoSer
# ============================================================
# Copia este archivo como .env.local y rellena con tus claves.
# NUNCA subas .env.local a git (ya está en .gitignore).
# ============================================================

# --- Supabase (obligatorias) ---
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_clave_publica_anon
SUPABASE_SERVICE_ROLE_KEY=tu_clave_secreta_de_servicio

# --- Cal.com (reservas) ---
NEXT_PUBLIC_CAL_BOOKING_URL=https://cal.com/tu-usuario/cita
CAL_WEBHOOK_SIGNING_KEY=tu_secreto_para_validar_webhooks

# --- HubSpot (CRM) ---
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxxxxxx

# --- Email (Brevo o HubSpot transactional) ---
# EMAIL_PROVIDER: "brevo" (envío real) | "hubspot" (stub, no envía)
# EMAIL_API_KEY: si provider=brevo, la API key de Brevo (empieza con "xkeysib-")
# EMAIL_FROM: debe ser un remitente VERIFICADO en Brevo (Settings → Senders)
EMAIL_PROVIDER=brevo
EMAIL_API_KEY=xkeysib-xxxxxxxxxxxx
EMAIL_FROM=neoser.admin@gmail.com

# --- Brevo Lists (sync automático de contactos) ---
# IDs numéricos de las listas creadas en Brevo (Contacts → Lists).
# Si estas vars están vacías, el sync se omite silenciosamente (no rompe nada).
BREVO_LIST_LEADS=
BREVO_LIST_ENROLLMENTS=
BREVO_LIST_BOOKINGS=

# --- WhatsApp (360dialog) ---
WHATSAPP_PROVIDER=360dialog
DIALOG_API_KEY=xxxxxxxxxxxx
WHATSAPP_FROM=51932713071
# Número de WhatsApp para el botón flotante y el CTA del sitio (sin +, sin espacios)
NEXT_PUBLIC_WHATSAPP_NUMBER=51978822368

# --- Google Maps ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXX

# --- Culqi (pagos de cursos) ---
# Llaves desde CulqiPanel > Desarrollo > API Keys (test/prod)
# La PUBLIC va al navegador (Custom Checkout). Las demás SOLO al servidor.
NEXT_PUBLIC_CULQI_PUBLIC_KEY=pk_test_xxxxx
CULQI_SECRET_KEY=sk_test_xxxxx
# (Opcional) Encriptación RSA del body — Fase 2.
# Si están vacías, el cargo se envía sin encriptar (auth Bearer ya basta).
CULQI_RSA_ID=
CULQI_RSA_PUBLIC_KEY=
# Secret configurado en CulqiPanel > Webhooks para verificar firma de eventos.
CULQI_WEBHOOK_SECRET=
