# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# excepcion: la plantilla SI debe subirse (no contiene secretos)
!.env.example

# scripts de debug/diagnostico locales (no subir: pueden imprimir
# fragmentos de claves o insertar datos de prueba en la BD real)
scripts/test-supabase.mjs

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
